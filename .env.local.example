# ─────────────────────────────────────────────
#  .env.local.example
#  Copie para .env.local e preencha os valores.
#  NUNCA commite .env.local no repositório.
# ─────────────────────────────────────────────

# ── Banco de dados (Neon / PostgreSQL) ────────
# Formato: postgresql://user:password@host.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ── Meta Conversions API (CAPI) ───────────────
# Pixel ID (só números, ex: 1234567890123456)
FB_PIXEL_ID=

# Token de acesso da CAPI — gerado em:
# Gerenciador de Eventos → Pixel → Configurações → Conversions API
FB_ACCESS_TOKEN=

# ── Meta Pixel (front-end) ────────────────────
# Mesmo Pixel ID acima, exposto ao browser via NEXT_PUBLIC_
NEXT_PUBLIC_FB_PIXEL_ID=
